<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product Id="*"
           Name="USB Descriptor Monitor"
           Language="1033"
           Version="1.0.0.0"
           Manufacturer="YourCompany"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">

    <Package InstallerVersion="200" Compressed="yes"
         InstallScope="perMachine" Platform="x64" />

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- ── Directories ── -->
    <Directory Id="TARGETDIR" Name="SourceDir">

      <!-- Program Files -->
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="USBMonitor" />
      </Directory>

      <!-- ProgramData (reserved WiX ID — no Name attribute needed) -->
      <Directory Id="ProgramDataFolder">
        <Directory Id="USBMonitorData" Name="USBMonitor" />
      </Directory>

    </Directory>

    <!-- ── Service Executable ── -->
    <ComponentGroup Id="ServiceComponents" Directory="INSTALLFOLDER">
      <Component Id="ServiceInstall" Guid="*" Win64="yes">
        <File Id="ServiceEXE"
              Source="..\build\USBMonitor.exe"
              KeyPath="yes" />

        <ServiceInstall Id="InstallService"
                        Type="ownProcess"
                        Name="USBDescriptorMonitor"
                        DisplayName="USB Descriptor Monitor"
                        Description="Logs USB device descriptors on plug-in events."
                        Start="auto"
                        Account="LocalSystem"
                        ErrorControl="normal" />

        <ServiceControl Id="StartService"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Name="USBDescriptorMonitor"
                        Wait="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Log Directory (ProgramData\USBMonitor) ── -->
    <ComponentGroup Id="LogDir" Directory="USBMonitorData">
      <Component Id="CreateLogDir" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <CreateFolder />
      </Component>
    </ComponentGroup>

    <!-- ── Feature ── -->
    <Feature Id="ProductFeature" Title="USB Monitor" Level="1">
      <ComponentGroupRef Id="ServiceComponents" />
      <ComponentGroupRef Id="LogDir" />
    </Feature>

  </Product>
</Wix>